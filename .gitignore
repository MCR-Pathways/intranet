# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/e2e/.auth/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# supabase
supabase/.temp/

# claude code — share project-scoped rules; keep personal/runtime files local
.claude/*
!.claude/rules/
!.claude/agents/
!.claude/commands/

# service account keys
*-service-key.json
mcr-pathways-*.json

# vercel
.vercel

# ralph loop runtime artifacts (history log + lock + stop signal are local)
scripts/ralph/ralph-history.log
scripts/ralph/.lock
scripts/ralph/.lock/
scripts/ralph/STOP

# typescript
*.tsbuildinfo
next-env.d.ts
